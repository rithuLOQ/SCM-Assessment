view.html (View + Delete Page)
<!DOCTYPE html>
<html>
<head>
    <title>View Tasks</title>
</head>
<body>

<h2>View Tasks (V3)</h2>

<p id="display"></p>

<button onclick="deleteTask()">Delete Task</button>

<br><br>
<a href="index.html">Back to Add Task</a>

<script>
function loadTask() {
    let task = localStorage.getItem("task");

    if(task) {
        document.getElementById("display").innerText = task;
    } else {
        document.getElementById("display").innerText = "No tasks available";
    }
}

function deleteTask() {
    localStorage.removeItem("task");
    document.getElementById("display").innerText = "Task Deleted!";
}

loadTask();
</script>

</body>
</html>

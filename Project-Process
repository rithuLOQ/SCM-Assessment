      function addEmployee() {
          const nameInput = document.getElementById('empName');
          const name = nameInput.value;
      
          if (name.trim() === "") {
              alert("Please enter a name!");
              return;
          }
      
          const employee = {
              id: Date.now(),
              name: name
          };
      
          let employees = JSON.parse(localStorage.getItem('employees')) || [];
          employees.push(employee);
          localStorage.setItem('employees', JSON.stringify(employees));
      
          document.getElementById('status-msg').innerText = `✅ Added: ${name}`;
          document.getElementById('status-msg').style.color = "#28a745";
          nameInput.value = ""; 
          
          displayEmployees();
      }
      
      function displayEmployees() {
          const employees = JSON.parse(localStorage.getItem('employees')) || [];
          const list = document.getElementById('employeeList');
          
          list.innerHTML = ""; 
          
          employees.forEach(emp => {
              const li = document.createElement('li');
              li.style.padding = "10px 0";
              li.style.borderBottom = "1px solid #eee";
              li.style.color = "#555";
              li.style.display = "flex";
              li.style.justifyContent = "space-between";
              li.style.alignItems = "center";
              
              // The new Delete Button logic!
              li.innerHTML = `
                  <span>🆔 ${emp.id} - 👤 ${emp.name}</span>
                  <button onclick="deleteEmployee(${emp.id})" style="background-color: #dc3545; color: white; border: none; padding: 5px 10px; font-size: 12px; border-radius: 4px; cursor: pointer;">Delete ❌</button>
              `;
              list.appendChild(li);
          });
      }
      
      function deleteEmployee(id) {
          let employees = JSON.parse(localStorage.getItem('employees')) || [];
          
          // Filter out the employee with the matching ID
          employees = employees.filter(emp => emp.id !== id);
          
          localStorage.setItem('employees', JSON.stringify(employees));
          
          // UI Feedback for deletion
          document.getElementById('status-msg').innerText = `🗑️ Employee Deleted!`;
          document.getElementById('status-msg').style.color = "#dc3545";
          
          displayEmployees(); // Refresh the list
      }
      
      // Load the list when the page first opens
      window.onload = displayEmployees;
      

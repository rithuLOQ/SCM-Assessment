          # 1. The Deployment: This pulls your image and runs the container
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: employee-v1-deployment
      spec:
        replicas: 1
        selector:
          matchLabels:
            app: employee-v1
        template:
          metadata:
            labels:
              app: employee-v1
          spec:
            containers:
            - name: employee-app
              image: rithulkanna/employee-system-agile:v1
              ports:
              - containerPort: 80
      
      ---
      # 2. The Service: This exposes the container to localhost:30001
      apiVersion: v1
      kind: Service
      metadata:
        name: employee-v1-service
